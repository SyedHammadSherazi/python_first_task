{
  "tasks": [
    {
      "name": "file",
      "type": "python",
      "file_path": "tasks/scripts/sample.txt",
      "enabled": true,
      "schedule": {
        "mode": "interval",
        "every": 1,
        "unit": "minutes"
      }
    },
    {
      "name": "file_daily",
      "type": "python",
      "file_path": "tasks/scripts/sample.txt",
      "enabled": false,
      "schedule": {
        "mode": "daily",
        "time": "15:40"
      }
    }
  ]
}
